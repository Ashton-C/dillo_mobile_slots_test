# Firebase — from Firebase Console → Project Settings → Your Apps → SDK config
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# AdMob app IDs — from https://admob.google.com → Apps → App ID  (ca-app-pub-XXX~YYY format)
# Leave blank in dev; prebuild falls back to Google test IDs automatically.
ADMOB_ANDROID_APP_ID=
ADMOB_IOS_APP_ID=

# AdMob rewarded ad unit IDs — from AdMob → Ad Units  (ca-app-pub-XXX/ZZZ format)
# Leave blank in dev; AdsService falls back to the fake-watch modal.
ADMOB_REWARDED_ANDROID=
ADMOB_REWARDED_IOS=

# AdMob interstitial ad unit IDs — same dashboard, separate units.
ADMOB_INTERSTITIAL_ANDROID=
ADMOB_INTERSTITIAL_IOS=

# RevenueCat — from RevenueCat dashboard → Project Settings → API keys
# Use the PUBLIC SDK keys (one per platform); the secret API key goes into
# Firebase Functions secrets, never in this file.
REVENUECAT_PUBLIC_KEY_IOS=
REVENUECAT_PUBLIC_KEY_ANDROID=
