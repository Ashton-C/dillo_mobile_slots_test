{
  "expo": {
    "name": "Reelwright",
    "slug": "reelwright",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "reelwright",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.reelwright.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "We use this to show you ads relevant to your interests, which keeps the game free."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D0D1A"
      },
      "package": "com.reelwright.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-tracking-transparency",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "REPLACE_WITH_ADMOB_ANDROID_APP_ID",
          "iosAppId": "REPLACE_WITH_ADMOB_IOS_APP_ID",
          "userTrackingPermission": "We use this to show you ads relevant to your interests, which keeps the game free."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "admob": {
        "rewardedIos": "REPLACE_WITH_ADMOB_REWARDED_IOS_UNIT_ID",
        "rewardedAndroid": "REPLACE_WITH_ADMOB_REWARDED_ANDROID_UNIT_ID",
        "interstitialIos": "REPLACE_WITH_ADMOB_INTERSTITIAL_IOS_UNIT_ID",
        "interstitialAndroid": "REPLACE_WITH_ADMOB_INTERSTITIAL_ANDROID_UNIT_ID"
      },
      "revenueCat": {
        "publicKeyIos": "REPLACE_WITH_REVENUECAT_IOS_PUBLIC_KEY",
        "publicKeyAndroid": "REPLACE_WITH_REVENUECAT_ANDROID_PUBLIC_KEY"
      }
    }
  }
}
